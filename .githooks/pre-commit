#!/bin/sh
# Blocks a commit when models.yaml or a shared partial has been edited but the
# generated files in the sibling consumer checkouts (my-dev-team,
# my-dev-team-vs-code) were not regenerated. Activate once per clone with:
#   git config core.hooksPath .githooks
root="$(git rev-parse --show-toplevel)"
[ -d "$root/../my-dev-team" ] && [ -d "$root/../my-dev-team-vs-code" ] || exit 0

# The check needs a Python with PyYAML; a bare `python` on PATH may be a clean
# system install without it (the hook does not inherit an activated venv).
# Prefer the sibling my-dev-team venv, where PyYAML is a dependency.
find_python() {
    for candidate in \
        "$root/../my-dev-team/venv/Scripts/python.exe" "$root/../my-dev-team/venv/bin/python" \
        "$root/../my-dev-team/.venv/Scripts/python.exe" "$root/../my-dev-team/.venv/bin/python" \
        python3 python py; do
        if "$candidate" -c "import yaml" >/dev/null 2>&1; then
            echo "$candidate"
            return 0
        fi
    done
    return 1
}

if ! python_bin="$(find_python)"; then
    echo "pre-commit: skipping the model-registry drift check - no Python with PyYAML found." >&2
    echo "Install it with: pip install pyyaml" >&2
    exit 0
fi

for script in sync_models.py sync_partials.py; do
    if ! "$python_bin" "$root/scripts/$script" --check; then
        echo ""
        echo "pre-commit: generated files are out of sync with this repo."
        echo "Run: python scripts/$script  - then commit here and in the consumer repos."
        exit 1
    fi
done
